#!/bin/bash

TESTDIR="examples"
WRONG="$(tput setaf 1)✗$(tput sgr0)"
CORRECT="$(tput setaf 2)✓$(tput sgr0)"
WARNING="$(tput setaf 3)⚠$(tput sgr0)"

echo '# Compiling...'
if ! make
then
    echo ''
    echo 'Compile fail.'
    exit 1
fi
echo ''

echo "# Testing CPS-convert (${WARNING} Alpha ver. )"

# One uniform list. A test with a .cc file is a callcc case (expected value in
# the .cc file); otherwise the converted program's value is checked.
for FULLNAME in $(find "${TESTDIR}"/test*.m | sort -V)
do
    TEST="$(basename -- "${FULLNAME}" .m)"
    FILE="${TESTDIR}/${TEST}"
    printf "Test %s..." "${TEST#test}"

    FAIL=0
    FAILMSG=""
    if ! ./run -checkcps "${FILE}.m" > /dev/null 2>&1; then
        FAIL=1; FAILMSG="Wrong CPS-converted expression"
    fi
    if [ -f "${FILE}.cc" ]; then
        if ! ./run -callcc "$(cat "${FILE}.cc")" "${FILE}.m" > /dev/null 2>&1; then
            FAIL=1; FAILMSG="Wrong callcc value"
        fi
    else
        if ! ./run -checkval "${FILE}.m" > /dev/null 2>&1; then
            FAIL=1; FAILMSG="Wrong result value"
        fi
    fi

    if [ 1 -eq ${FAIL} ]; then
        echo "${WRONG} : ${FAILMSG}"
    else
        echo "${CORRECT}"
    fi
done
echo "(${WARNING} Alpha ver. CPS expression check is not reliable. )"
